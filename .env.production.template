# =============================================================================
# Agent9 / Decision Studio — Production Environment Template
# =============================================================================
# Copy to .env and fill in real values before deploying.
# NEVER commit the filled .env file — only this template is checked in.
# =============================================================================

# ─── Domain Configuration ────────────────────────────────────────────────────
# Used by CORS and frontend API routing
FRONTEND_URL=https://app.trydecisionstudio.com
API_URL=https://api.trydecisionstudio.com

# ─── Supabase Cloud ──────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Registry Backends (all Supabase in production) ──────────────────────────
BUSINESS_GLOSSARY_BACKEND=supabase
PRINCIPAL_PROFILE_BACKEND=supabase
KPI_REGISTRY_BACKEND=supabase
BUSINESS_PROCESS_BACKEND=supabase
DATA_PRODUCT_BACKEND=supabase
BUSINESS_CONTEXT_BACKEND=supabase
ACTIVE_CLIENT_ID=lubricants
A9_BUSINESS_CONTEXT=lubricants

# ─── LLM Providers ──────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...your-key
# Optional: OpenAI fallback
# OPENAI_API_KEY=sk-...your-key

# ─── External Services ──────────────────────────────────────────────────────
# Perplexity (Market Analysis Agent)
# PERPLEXITY_API_KEY=pplx-...your-key

# BigQuery (optional — only if customer has BigQuery data products)
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/bigquery-key.json

# ─── Application Settings ───────────────────────────────────────────────────
LOG_LEVEL=WARNING
CACHE_URL=memory://
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_REAL_TIME_MONITORING=true
FEATURE_AI_SUGGESTIONS=true
A9_ENABLE_LLM_SQL=true

# ─── Security ───────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
API_KEY=generate-a-strong-api-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Sentry (Error Monitoring) ──────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ─── Email (Resend or SendGrid) ─────────────────────────────────────────────
# RESEND_API_KEY=re_...your-key
