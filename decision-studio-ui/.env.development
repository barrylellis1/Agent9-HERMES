# Development: local backend (default — no change needed)
VITE_API_URL=http://127.0.0.1:8000

# Debate mode: "fast" (2 calls: stage1 + synthesis) or "full" (4 calls: all stages)
# Fast mode cuts SF latency from ~9 min to ~3 min with equivalent output quality
VITE_DEBATE_MODE=fast

# Supabase Auth — Infra B
# Local dev keys (from supabase status / supabase.io project settings)
VITE_SUPABASE_URL=http://127.0.0.1:54321
