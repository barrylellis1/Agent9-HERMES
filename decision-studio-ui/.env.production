# Production: points to the deployed API
VITE_API_URL=https://api.trydecisionstudio.com

# Full debate mode in production — all 4 stages for maximum depth
VITE_DEBATE_MODE=full

# Supabase Auth — Infra B
# Set these in Cloudflare Pages environment variables dashboard.
# Get values from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-replace-in-cloudflare-pages-env

# Tenant domain → client_id mapping (comma-separated domain:client_id pairs)
# Example: apex.com:apex_lubricants,hess.com:hess
# Set in Cloudflare Pages environment variables.
VITE_TENANT_DOMAIN_MAP=
